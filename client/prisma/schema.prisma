// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Project {
  id         Int               @id @default(autoincrement())
  title      String
  tags       ProjectTag[]
  projectUrl String?
  githubUrl  String?
  techItems  ProjectTechItem[]
  roles      ProjectRole[]
  sections   Section[]

  @@map("project")
}

model Tag {
  id       Int          @id @default(autoincrement())
  name     String       @unique
  projects ProjectTag[]

  @@map("tag")
}

model ProjectTag {
  projectId Int
  tagId     Int
  order     Int
  project   Project @relation(fields: [projectId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([projectId, tagId])
  @@map("project_tag")
}

model TechItem {
  id         Int               @id @default(autoincrement())
  name       String           @unique
  slug       String            @unique
  isFrontend Boolean           @default(false)
  isBackend  Boolean           @default(false)
  projects   ProjectTechItem[]

  @@map("tech_item")
}

enum TechCategory {
  frontend
  backend
}

model ProjectTechItem {
  projectId  Int
  techItemId Int
  category   TechCategory
  order      Int
  project    Project      @relation(fields: [projectId], references: [id])
  techItem   TechItem     @relation(fields: [techItemId], references: [id])

  @@id([projectId, techItemId, category])
  @@map("project_tech_item")
}

model Role {
  id       Int           @id @default(autoincrement())
  name     String        @unique
  projects ProjectRole[]

  @@map("role")
}

model ProjectRole {
  projectId Int
  roleId    Int
  order     Int
  project   Project @relation(fields: [projectId], references: [id])
  role      Role    @relation(fields: [roleId], references: [id])

  @@id([projectId, roleId])
  @@map("project_role")
}

model Section {
  id            Int            @id @default(autoincrement())
  order         Int
  title         String
  layoutType    LayoutType
  projectId     Int
  project       Project        @relation(fields: [projectId], references: [id])
  contentTexts  ContentText[]
  contentImages ContentImage[]
  contentVideos ContentVideo[]

  @@map("section")
}

enum LayoutType {
  imgTopTextBottom
  imgLeftTextRight
  imgRightTextLeft
  textTopImgMiddleTextBottom
}

model ContentText {
  id        Int     @id @default(autoincrement())
  content   String  @db.LongText
  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  @@map("content_text")
}

model ContentImage {
  id        Int     @id @default(autoincrement())
  url       String  @db.Text
  alt       String?
  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  @@map("content_image")
}

model ContentVideo {
  id        Int     @id @default(autoincrement())
  url       String  @db.Text
  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  @@map("content_video")
}
